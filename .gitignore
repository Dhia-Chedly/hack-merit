# ═══════════════════════════════════════════
# TerraLens AI — .gitignore
# ═══════════════════════════════════════════

# ── Dependencies ──
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ── Build outputs ──
frontend/.next/
frontend/out/
frontend/build/
.next/
out/
dist/
build/

# ── Environment & secrets ──
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.so
.venv/
venv/
env/
.Python

# ── IDE ──
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ── Debug & logs ──
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Testing ──
coverage/
.nyc_output/

# ── OS files ──
*.log
*.tmp
*.bak
*.orig

# ── Large data files (keep in repo via LFS or exclude) ──
# Uncomment below if GeoJSON files are too large for GitHub:
# geoBoundaries-TUN-ADM3.geojson
# frontend/public/data/geodata/adm3.geojson

# ── Vercel ──
.vercel

# ── Turbopack ──
.turbo

terralens_logo.png
design_terralens.md 
tecnocasa-tn.svg